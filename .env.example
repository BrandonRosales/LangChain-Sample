# === LLM Provider ===
GEMINI_API_KEY=your-gemini-api-key-here

# === Search Provider (pick one) ===
TAVILY_API_KEY=your-tavily-api-key-here

# === Optional ===
# MODEL_NAME=gemini-flash-latest    # Default, works with free tier
# MODEL_NAME=gemini-2.0-flash        # Also free tier
# MODEL_NAME=gemini-2.5-flash        # Newer, also free tier
# TEMPERATURE=0.3

# === Mock Mode (for testing without API credits) ===
# MOCK_MODE=auto    # auto = use mocks if no API key, true = always use mocks, false = never use mocks
# Useful if you've exhausted free tier or want to test the pipeline structure
